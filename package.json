{
  "name": "mi-bachelor-abschlussarbeiten",
  "version": "1.0.0",
  "description": "Abschlussarbeiten Medieninformatik Bachelor und Master",
  "main": "index.html",
  "scripts": {
    "jekyll:serve": "bundle exec jekyll serve --livereload",
    "test": "echo \"Error: no test specified\" && exit 1",
    "css:dev": "npx @tailwindcss/cli -i ./assets/css/input.css -o ./assets/css/output.css --watch",
    "css:build": "npx @tailwindcss/cli -i ./assets/css/input.css -o ./assets/css/output.css --minify",
    "dev": "npm-run-all --parallel css:dev jekyll:serve",
    "build": "npm run css:build && bundle exec jekyll build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/th-koeln/mi-bachelor-abschlussarbeiten.git"
  },
  "author": "Volker Schaefer",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/th-koeln/mi-bachelor-abschlussarbeiten/issues"
  },
  "homepage": "https://github.com/th-koeln/mi-bachelor-abschlussarbeiten#readme",
  "dependencies": {
    "jekyll": "^3.0.0-beta1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.14",
    "@tailwindcss/postcss": "^4.1.14",
    "autoprefixer": "^10.4.21",
    "cssnano": "^7.1.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.14"
  }
}
